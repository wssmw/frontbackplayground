{
  "name": "front-back-playground",
  "version": "0.1.0",
  "private": true,
  "description": "前后端分离交互学习实验室：Vue + Element Plus + Tailwind、NestJS、VitePress。",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:frontend": "pnpm --filter @fbp/frontend dev",
    "dev:backend": "pnpm --filter @fbp/backend dev",
    "dev:docs": "pnpm --filter @fbp/docs dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint . && prettier --check .",
    "lint:fix": "eslint . --fix && prettier --write .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.10.2",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.1",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.59.2"
  },
  "dependencies": {
    "pnpm": "^10.33.4"
  }
}
