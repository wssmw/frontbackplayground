{
  "name": "front-back-playground",
  "version": "0.1.0",
  "private": true,
  "description": "前后端分离交互学习实验室：Vue + Element Plus + Tailwind、NestJS、VitePress。",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:frontend": "pnpm --filter @fbp/frontend dev",
    "dev:backend": "pnpm --filter @fbp/backend dev",
    "dev:docs": "pnpm --filter @fbp/docs dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  }
}
